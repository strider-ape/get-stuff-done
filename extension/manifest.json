{
  "manifest_version": 3,
  "name": "Get Stuff Done!",
  "version": "0.0.0",
  "description": "A dead-simple daily checklist. No account. No cloud. No nonsense.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [],
  "host_permissions": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "get-stuff-done@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}